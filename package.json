{
  "name": "@jplannnou/support-sdk",
  "version": "0.2.0",
  "description": "ChatWidget + hooks for in-app conversational support, backed by the Gundo Feedback Hub unified inbox.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "copy-assets": "node -e \"const fs=require('fs'),p=require('path');(function cp(s,d){fs.readdirSync(s,{withFileTypes:true}).forEach(e=>{if(e.isDirectory())cp(p.join(s,e.name),p.join(d,e.name));else if(e.name.endsWith('.css')){fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p.join(s,e.name),p.join(d,e.name))}})})('src','dist')\"",
    "build": "tsc && pnpm copy-assets",
    "prepublishOnly": "pnpm build",
    "release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jplannnou/gundo-support-sdk.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/react": "^19.0.0",
    "semantic-release": "^24.2.0",
    "typescript": "^5.9.0"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      ["@semantic-release/npm", { "npmPublish": true }],
      ["@semantic-release/git", {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }],
      "@semantic-release/github"
    ]
  }
}
